---
import { twMerge } from "tailwind-merge";

interface Props {
    fullWidth?: boolean;
    fullHeight?: boolean;
    class?: string;
}

const { fullWidth = false, fullHeight = false, class: className } = Astro.props

const classes = twMerge(
    "glass flex flex-col text-text border border-night-border rounded-xl p-4 transition-colors duration-200 hover:border-kiwi/30",
    fullWidth  ? "w-full"  : "",
    fullHeight ? "h-full"  : "",
    className
)
---
<div class={classes}>
    <slot/>
</div>