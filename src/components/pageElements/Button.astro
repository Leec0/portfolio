---
import type {HTMLAttributes} from "astro/types";
import { cva } from "class-variance-authority";
import { twMerge } from "tailwind-merge";

interface Props extends HTMLAttributes<"button"> {
    type?: "button" | "submit";
    size?: "sm" | "default" | "lg" | "icon";
    variant?: "default" | "outline" | "secondary" | "ghost" | "link" | "inactive" | "active";
    class?: string;
    href?: string;
}

const {
    type = "button",
    size = "default",
    variant = "default",
    class: className,
    href,
    ...rest
} = Astro.props

const buttonVariants = cva(
    "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-semibold transition-all duration-200 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none shrink-0 outline-none focus-visible:ring-2 focus-visible:ring-kiwi/50 focus-visible:ring-offset-2 focus-visible:ring-offset-night cursor-pointer",
    {
        variants: {
            variant: {
                default:   "bg-kiwi text-night hover:bg-kiwi-dim hover:shadow-md active:scale-95",
                outline:   "border-2 border-kiwi bg-transparent text-kiwi hover:bg-kiwi/10 active:scale-95",
                secondary: "bg-night-surface text-text border border-night-border hover:border-kiwi/60 hover:text-kiwi active:scale-95",
                ghost:     "text-text hover:bg-kiwi/10 hover:text-kiwi active:scale-95",
                link:      "text-kiwi underline-offset-4 hover:underline",
                inactive:  "border border-night-border text-text-muted hover:border-kiwi hover:text-kiwi active:scale-95",
                active:    "bg-kiwi text-night hover:bg-kiwi-dim active:scale-95",
            },
            size: {
                sm:      "h-9 px-3 py-1.5 text-xs",
                default: "h-10 px-5 py-2.5",
                lg:      "h-11 px-7 py-2.5 text-base",
                icon:    "size-10",
            },
        },
        defaultVariants: {
            variant: "default",
            size: "default",
        },
    }
)

const classes = twMerge(buttonVariants({ variant, size }), className)
---
{href ? (
    <a href={href} class={classes} {...rest}><slot/></a>
) : (
    <button type={type} class={classes} {...rest}><slot/></button>
)}
